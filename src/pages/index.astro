  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#040404]/65 backdrop-blur-xl transition-all duration-300"
>
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">

        <!-- BRAND -->
        <a href="#" class="flex items-center gap-3">
