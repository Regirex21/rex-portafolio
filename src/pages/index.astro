            RS
          </div>

          <span class="hidden text-lg font-semibold text-zinc-200 md:block">
            Regina Servín
          </span>
        </a>

        <!-- MENU -->
      <div class="hidden md:flex items-center gap-10 text-sm font-medium text-zinc-400">
          <a href="/" class="hover:text-white transition">Inicio</a>
          <a href="/projects" class="hover:text-white transition">Proyectos</a>
          <a href="/about" class="hover:text-white transition">Sobre mí</a>
          <a href="/contact" class="hover:text-white transition">Contacto</a>
      </div>
        <!-- ACTIONS -->
        <div class="hidden md:flex items-center gap-3">

          <div class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300">
            ES <span class="px-1 text-zinc-600">|</span> EN
          </div>

          <a
            href="https://github.com/Regirex21"
            target="_blank"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:border-[#86B84C]"
          >
            GitHub
          </a>

          <a
            href="https://www.linkedin.com/in/regina-servín/"
            target="_blank"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:border-[#86B84C]"
