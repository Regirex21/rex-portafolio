        </div>

      </nav>
    </header>

    <!-- HERO -->
    <section class="relative mx-auto max-w-7xl px-6 pt-20 pb-28 reveal">

      <div class="grid items-center gap-20 lg:grid-cols-2">

        <!-- LEFT -->
