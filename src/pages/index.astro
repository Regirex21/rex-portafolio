      <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Notion</span>

    </div>

    <!-- INFO BAR -->
    <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4 reveal">

  <!-- UNIVERSIDAD -->
  <div class="rounded-2xl border border-white/10 bg-[#111] p-5">
    <div class="flex items-start gap-4">
      <img src="icons/star-svgrepo-com.svg" class="h-8 w-8 mt-1" alt="Universidad" />

      <div>
        <p class="text-sm text-zinc-500">Universidad</p>
        <p class="mt-1 font-semibold">Tecmilenio</p>
      </div>
