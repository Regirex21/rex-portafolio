---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Sobre mí | Regina Servín"
  description="Conoce más sobre Regina Servín, estudiante de ingeniería en desarrollo de software."
>
  <main class="min-h-screen overflow-x-hidden bg-[#040404] text-white">

    <!-- HERO -->
    <section class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 sm:px-6 md:pt-10 md:pb-20">
      <div class="absolute right-[-120px] top-10 h-[320px] w-[320px] rounded-full bg-[#86B84C]/10 blur-3xl sm:right-0 sm:h-[420px] sm:w-[420px]"></div>

      <div class="grid gap-14 lg:grid-cols-2 lg:items-center">

        <!-- LEFT -->
        <div class="relative z-10">

          <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-[#86B84C]">
            Sobre mí
          </span>

          <h1 class="mt-6 text-4xl font-black leading-tight sm:text-5xl md:text-6xl">
            Aprendiendo<br />
            Liderando<br />
            <span class="text-[#86B84C]">Creando</span>
          </h1>

          <p class="mt-6 max-w-xl text-base leading-7 text-zinc-400 sm:text-lg sm:leading-8">
            Soy estudiante de Ingeniería en Desarrollo de Software con experiencia
            real liderando equipos, creando sistemas web y mejorando procesos.
            Me enfoco en resolver problemas y seguir creciendo profesionalmente.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">

            <a
              href="/projects"
              class="w-full rounded-2xl bg-[#86B84C] px-6 py-3 text-center font-semibold text-black transition hover:scale-105 sm:w-auto"
            >
              Ver proyectos →
            </a>

            <a
              href="/#contact"
              class="w-full rounded-2xl border border-white/10 px-6 py-3 text-center font-semibold transition hover:border-[#86B84C] sm:w-auto"
            >
              Contacto
            </a>

          </div>
        </div>

        <!-- RIGHT CARD -->
        <div class="relative z-10">
          <div class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur-xl sm:p-8">

            <h3 class="text-xl font-bold">
              Perfil rápido
            </h3>

            <div class="mt-6 space-y-5 text-zinc-300">

              <div class="flex flex-col gap-1 border-b border-white/5 pb-3 sm:flex-row sm:items-center sm:justify-between">
                <span>Universidad</span>
                <span class="font-semibold text-white">Tecmilenio</span>
              </div>

              <div class="flex flex-col gap-1 border-b border-white/5 pb-3 sm:flex-row sm:items-center sm:justify-between">
                <span>Ubicación</span>
                <span class="font-semibold text-white">México</span>
              </div>

              <div class="flex flex-col gap-1 border-b border-white/5 pb-3 sm:flex-row sm:items-center sm:justify-between">
                <span>Idiomas</span>
                <span class="font-semibold text-white">Español / Inglés</span>
              </div>

              <div class="flex flex-col gap-1 border-b border-white/5 pb-3 sm:flex-row sm:items-center sm:justify-between">
                <span>Disponibilidad</span>
                <span class="font-semibold text-[#86B84C]">
                  Disponible para trabajar
                </span>
              </div>

            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- TRAYECTORIA -->
    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">

      <h2 class="text-3xl font-black sm:text-4xl">
        Mi trayectoria
      </h2>

      <div class="mt-12 grid gap-8 md:grid-cols-2">

        <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-5 sm:p-7">
          <span class="font-semibold text-[#86B84C]">01</span>

          <h3 class="mt-3 text-2xl font-bold">
            Liderazgo en robótica
          </h3>

          <p class="mt-3 leading-7 text-zinc-400">
            Formación y liderazgo dentro de equipos FIRST Robotics,
            coordinando personas, procesos y crecimiento técnico.
          </p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-5 sm:p-7">
          <span class="font-semibold text-[#86B84C]">02</span>

          <h3 class="mt-3 text-2xl font-bold">
            Desarrollo web
          </h3>

          <p class="mt-3 leading-7 text-zinc-400">
            Creación de sitios modernos, funcionales y orientados a objetivos reales.
          </p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-5 sm:p-7">
          <span class="font-semibold text-[#86B84C]">03</span>

          <h3 class="mt-3 text-2xl font-bold">
            Pensamiento sistémico
          </h3>

          <p class="mt-3 leading-7 text-zinc-400">
            Organización de recursos, documentación y procesos internos eficientes.
          </p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-5 sm:p-7">
          <span class="font-semibold text-[#86B84C]">04</span>

          <h3 class="mt-3 text-2xl font-bold">
            Crecimiento constante
          </h3>

          <p class="mt-3 leading-7 text-zinc-400">
            Aprendo rápido, mejoro continuamente y busco nuevos retos.
          </p>
        </div>

      </div>
    </section>

    <!-- HABILIDADES -->
    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">

      <h2 class="text-3xl font-black sm:text-4xl">
        Habilidades y fortalezas
      </h2>

      <div class="mt-10 flex flex-wrap gap-4">

        {[
          "Java",
          "Python",
          "Astro",
          "HTML/CSS",
          "Git",
          "Liderazgo",
          "Resolución de problemas",
          "Documentación",
          "Trabajo en equipo",
          "Diseño UI",
          "Comunicación efectiva",
          "Aprendizaje rápido",
          "Pensamiento sistémico",
          "Gestión de proyectos",
          "Adaptabilidad",
        ].map((skill) => (
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2.5 text-sm text-zinc-300 transition hover:border-[#86B84C] hover:text-white sm:px-5 sm:py-3">
            {skill}
          </span>
        ))}

      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-20">

      <div class="rounded-[28px] border border-white/10 bg-white/[0.02] p-5 sm:p-8 md:flex md:items-center md:justify-between md:rounded-[32px] md:p-10">

        <div>
          <h2 class="text-3xl font-black sm:text-4xl">
            Construyamos algo grande
          </h2>

          <p class="mt-4 text-zinc-400">
            Disponible para prácticas, freelance y oportunidades junior.
          </p>
        </div>

        <a
          href="/#contact"
          class="mt-6 inline-block w-full rounded-2xl bg-[#86B84C] px-7 py-4 text-center font-semibold text-black transition hover:scale-105 sm:w-auto md:mt-0"
        >
          Hablemos →
        </a>

      </div>

    </section>

  </main>
</Layout>
