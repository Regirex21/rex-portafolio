---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  lang="en"
  title="Projects | Regina Servín"
  description="Project portfolio by Regina Servín: web development, internal systems, and technical documentation."
>
  <main class="min-h-screen overflow-x-hidden bg-[#040404] text-white">

    <!-- HERO -->
    <section class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 sm:px-6 md:pt-10 md:pb-20">

      <div class="absolute right-[-120px] top-10 h-[320px] w-[320px] rounded-full bg-[#86B84C]/10 blur-3xl sm:right-0 sm:h-[420px] sm:w-[420px]"></div>

      <div class="relative z-10 max-w-4xl">

        <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-[#86B84C]">
          Projects
        </span>

        <h1 class="mt-6 text-4xl font-black leading-tight sm:text-5xl md:text-6xl">
          Real projects.<br />
          <span class="text-[#86B84C]">Useful solutions.</span>
        </h1>

        <p class="mt-6 max-w-3xl text-base leading-7 text-zinc-400 sm:text-lg sm:leading-8">
          Websites, internal platforms, and documentation created with a practical
          mindset. I enjoy building functional tools that improve processes and
          create real value.
        </p>

      </div>

    </section>

    <!-- FEATURED PROJECT -->
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 md:pb-20">

      <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-4 sm:p-6 md:rounded-[36px] lg:p-10">

        <div class="grid gap-10 lg:grid-cols-2 lg:items-center">

          <!-- IMAGE -->
          <div>
            <img
              src="/components/docs.png"
              alt="FIRSTHub Docs"
              class="aspect-video h-auto w-full rounded-2xl border border-white/10 object-cover md:rounded-3xl"
            />
          </div>

          <!-- CONTENT -->
          <div>

            <span class="text-sm font-semibold text-[#86B84C]">
              Featured project
            </span>

            <h2 class="mt-4 text-3xl font-black sm:text-4xl">
              FIRSTHub Docs
            </h2>

            <p class="mt-5 leading-8 text-zinc-400">
              A technical documentation system designed for fast training,
              efficient onboarding, and knowledge transfer within teams.
            </p>

            <div class="mt-6 flex flex-wrap gap-3">

              <span class="rounded-full border border-white/10 px-4 py-2 text-sm">
                Docs
              </span>

              <span class="rounded-full border border-white/10 px-4 py-2 text-sm">
                UX Writing
              </span>

              <span class="rounded-full border border-white/10 px-4 py-2 text-sm">
                Architecture
              </span>

              <span class="rounded-full border border-white/10 px-4 py-2 text-sm">
                Scalability
              </span>

            </div>

            <div class="mt-8 flex flex-wrap gap-3 sm:gap-4">

              <a
                href="https://firsthub-docs.vercel.app"
                target="_blank"
                class="w-full rounded-2xl bg-[#86B84C] px-6 py-3 text-center font-semibold text-black transition hover:scale-105 sm:w-auto"
              >
                View project →
              </a>

              <a
                href="https://github.com/Regirex21"
                target="_blank"
                class="w-full rounded-2xl border border-white/10 px-6 py-3 text-center font-semibold transition hover:border-[#86B84C] sm:w-auto"
              >
                GitHub
              </a>

            </div>

          </div>

        </div>

      </div>

    </section>

    <!-- PROJECT GRID -->
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 md:pb-20">

      <div class="grid gap-8 lg:grid-cols-2">

        <!-- ARIA -->
        <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-4 sm:p-6 md:rounded-[32px]">

          <img
            src="/components/aria.png"
            alt="ARIA Website"
            class="h-44 w-full rounded-2xl border border-white/10 object-cover sm:h-56"
          />

          <h3 class="mt-6 text-2xl font-black sm:text-3xl">
            ARIA Website
          </h3>

          <p class="mt-4 leading-7 text-zinc-400">
            A modern website focused on branding, digital presence, and
            professional visual communication.
          </p>

          <div class="mt-5 flex flex-wrap gap-3">
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">Frontend</span>
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">UI Design</span>
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">Responsive</span>
          </div>

          <a
            href="https://aria-steamex.vercel.app"
            target="_blank"
            class="mt-6 inline-block text-[#86B84C] transition hover:opacity-80"
          >
            View project →
          </a>

        </div>

        <!-- FIRSTHUB PLATFORM -->
        <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-4 sm:p-6 md:rounded-[32px]">

          <img
            src="/components/firsthub.png"
            alt="FIRSTHub Platform"
            class="h-44 w-full rounded-2xl border border-white/10 object-cover sm:h-56"
          />

          <h3 class="mt-6 text-2xl font-black sm:text-3xl">
            FIRSTHub Platform
          </h3>

          <p class="mt-4 leading-7 text-zinc-400">
            A platform created to centralize resources, internal organization,
            and training materials.
          </p>

          <div class="mt-5 flex flex-wrap gap-3">
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">Astro</span>
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">Tailwind</span>
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm">UX</span>
          </div>

          <a
            href="https://firsthub.vercel.app"
            target="_blank"
            class="mt-6 inline-block text-[#86B84C] transition hover:opacity-80"
          >
            View project →
          </a>

        </div>

      </div>

    </section>

    <!-- EXPERIENCE -->
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 md:pb-20">

      <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-5 sm:p-8 md:rounded-[32px]">

        <h2 class="text-3xl font-black sm:text-4xl">
          Applied experience
        </h2>

        <div class="mt-10 grid gap-8 md:grid-cols-2">

          <div>
            <h3 class="text-2xl font-bold text-[#86B84C]">
              FIRST Robotics Leadership
            </h3>

            <p class="mt-4 leading-8 text-zinc-400">
              Leadership in robotics teams, member training, internal
              organization, planning, and problem solving in demanding environments.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-bold text-[#86B84C]">
              Builder mindset
            </h3>

            <p class="mt-4 leading-8 text-zinc-400">
              A focus on turning real needs into functional solutions by
              iterating on design, structure, and user experience.
            </p>
          </div>

        </div>

      </div>

    </section>

    <!-- LEARNINGS -->
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 md:pb-20">

      <h2 class="text-3xl font-black sm:text-4xl">
        What I have learned by building
      </h2>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">

        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
          Visual clarity matters.
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
          Simple systems scale better.
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
          Iteration improves every product.
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
          The user always comes first.
        </div>

      </div>

    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 md:pb-24">

      <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-5 sm:p-8 md:flex md:items-center md:justify-between md:rounded-[32px] md:p-10">

        <div>
          <h2 class="text-3xl font-black sm:text-4xl">
            Shall we work together?
          </h2>

          <p class="mt-4 text-zinc-400">
            Available for junior opportunities, freelance work, or remote projects.
          </p>
        </div>

        <a
          href="/en/contact"
          class="mt-6 inline-block w-full rounded-2xl bg-[#86B84C] px-7 py-4 text-center font-semibold text-black transition hover:scale-105 sm:w-auto md:mt-0"
        >
          Contact me →
        </a>

      </div>

    </section>

  </main>
</Layout>
