              class="relative rounded-[32px] border border-white/10 bg-[#090909] p-8 shadow-[0_30px_90px_rgba(0,0,0,0.55)] transition-transform duration-200 reveal"
            >

              <!-- top dots -->
              <div class="mb-8 flex gap-2">
                <div class="h-3 w-3 rounded-full bg-[#8b2a2a]"></div>
                <div class="h-3 w-3 rounded-full bg-[#8b6a2a]"></div>
                <div class="h-3 w-3 rounded-full bg-[#2f8b2a]"></div>
              </div>

              <p class="mb-6 text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
                Developer Profile
              </p>

              <pre class="overflow-hidden rounded-2xl bg-[#050505] p-6 text-[15px] leading-8 text-zinc-300">
<code id="typingCode"></code><span class="animate-pulse text-[#86B84C]">|</span>
              </pre>

            </div>
