      <div class="rounded-[28px] border border-white/10 bg-[#0b0b0b] p-5 sm:p-8 md:rounded-[32px] md:p-10 reveal">
        <h2 class="text-3xl font-black tracking-tight sm:text-4xl md:text-5xl">
