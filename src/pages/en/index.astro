      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#040404]/65 backdrop-blur-xl transition-all duration-300"
    >
      <nav class="mx-auto flex max-w-7xl items-center justify-center px-4 py-3 sm:px-6 md:justify-between md:py-4">

        <!-- BRAND -->
        <a href="/en/" class="hidden items-center gap-3 md:flex">
          <div class="rounded-xl border border-[#86B84C]/20 bg-[#86B84C]/10 px-3 py-2 text-xl font-black text-[#86B84C]">
            RS
          </div>

          <span class="hidden text-lg font-semibold text-zinc-200 md:block">
            Regina Servín
          </span>
        </a>

        <!-- MENU -->
        <div class="flex w-full items-center justify-center gap-2 overflow-x-auto whitespace-nowrap text-sm font-medium text-zinc-400 md:w-auto md:justify-start md:gap-10 md:overflow-visible">
          <a href="/en/" class="rounded-full border border-white/10 px-3 py-2 transition hover:text-white md:border-0 md:px-0 md:py-0">Home</a>
          <a href="/en/projects" class="rounded-full border border-white/10 px-3 py-2 transition hover:text-white md:border-0 md:px-0 md:py-0">Projects</a>
          <a href="/en/about" class="rounded-full border border-white/10 px-3 py-2 transition hover:text-white md:border-0 md:px-0 md:py-0">About me</a>
          <a href="/en/contact" class="rounded-full border border-white/10 px-3 py-2 transition hover:text-white md:border-0 md:px-0 md:py-0">Contact</a>
        </div>

        <!-- ACTIONS -->
        <div class="hidden md:flex items-center gap-3">

          <a
            href="/"
            aria-label="Cambiar a español"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:border-[#86B84C] hover:text-white"
          >
            EN <span class="px-1 text-zinc-600">|</span> ES
          </a>

          <a
            href="https://github.com/Regirex21"
            target="_blank"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:border-[#86B84C]"
          >
            GitHub
          </a>

          <a
            href="https://www.linkedin.com/in/regina-servín/"
            target="_blank"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-zinc-300 transition hover:border-[#86B84C]"
          >
            LinkedIn
          </a>

        </div>

      </nav>
    </header>

    <!-- HERO -->
    <section class="relative mx-auto max-w-7xl px-4 pt-8 pb-20 sm:px-6 md:pb-28 md:pt-16 reveal">

      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">

        <!-- LEFT -->
        <div>

          <!-- AVAILABLE BADGE -->
          <div class="mb-6 inline-flex max-w-full items-center gap-3 rounded-full border border-white/10 bg-[#101010] px-4 py-3 reveal sm:px-5 md:mb-8">
            <span class="h-3 w-3 rounded-full bg-[#86B84C] shadow-[0_0_15px_#86B84C]"></span>

            <span class="text-sm font-medium text-zinc-200">
              Available for work
            </span>
          </div>

          <!-- NAME -->
          <h1 class="text-4xl font-black leading-[1.02] tracking-tight sm:text-5xl md:text-6xl xl:text-[4.8rem] reveal">
            Regina <span class="text-[#86B84C]">Servín</span>
          </h1>

          <!-- ROLE -->
          <p class="mt-6 max-w-3xl text-xl font-medium leading-snug text-zinc-200 sm:text-2xl md:mt-8 reveal">
            Software Development Engineering Student <br />
            | Junior Developer
          </p>

          <!-- DESCRIPTION -->
          <p class="mt-6 max-w-2xl text-base leading-relaxed text-zinc-400 sm:text-lg md:mt-8 reveal">
            I build functional web solutions, organized systems, and technical
            documentation. I enjoy solving problems, learning quickly, and
            working with teams.
          </p>

          <!-- BUTTONS -->
          <div class="mt-8 flex flex-wrap gap-3 items-center reveal sm:gap-4 md:mt-10">

            <a
              href="/en/projects"
              class="w-full rounded-2xl bg-[#86B84C] px-6 py-4 text-center text-base font-semibold text-black shadow-[0_0_24px_rgba(134,184,76,0.18)] transition hover:scale-[1.02] hover:bg-[#93c957] sm:w-auto sm:px-8 sm:text-lg"
