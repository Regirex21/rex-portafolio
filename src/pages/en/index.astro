              class="w-full rounded-2xl border border-white/10 px-6 py-4 text-center text-base font-semibold text-white transition hover:border-[#86B84C] hover:text-[#86B84C] sm:w-auto sm:px-8 sm:text-lg"
            >
              View resume
            </a>

            <!-- LINKEDIN -->
            <a
              href="https://www.linkedin.com/in/regina-servín/"
