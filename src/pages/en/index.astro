        </h2>

        <!-- BENEFITS -->
        <div class="mt-10 grid gap-8 sm:grid-cols-2 xl:grid-cols-4 md:mt-12">

          <div>
            <img src="/icons/alt-plus-lens-svgrepo-com.svg" class="h-10 w-10 mb-4" alt="" />
