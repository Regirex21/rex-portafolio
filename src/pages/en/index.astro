            <h2 class="text-3xl font-black tracking-tight sm:text-4xl md:text-5xl">
              Have a project in mind?
            </h2>

            <p class="mt-4 max-w-2xl text-lg text-zinc-400">
              Available for part-time, freelance, and remote opportunities.
            </p>
          </div>

          <!-- BUTTON -->
          <div>
            <a
              href="mailto:r.servin19@hotmail.com"
              class="inline-flex w-full justify-center rounded-2xl bg-[#86B84C] px-8 py-4 text-lg font-semibold text-black transition hover:opacity-90 sm:w-auto"
            >
              Let's talk →
            </a>
          </div>

        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-white/10 py-8">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 text-sm text-zinc-500 sm:px-6 md:flex-row md:items-center md:justify-between">

        <div>
          <p class="font-medium text-zinc-300">Regina Servín</p>
          <p>Software Developer</p>
        </div>

        <div class="flex items-center gap-5">
          <a
            href="https://github.com/Regirex21"
            target="_blank"
            class="hover:text-[#86B84C] transition"
          >
            GitHub
          </a>

          <a
            href="https://www.linkedin.com/in/regina-servín/"
            target="_blank"
            class="hover:text-[#86B84C] transition"
          >
            LinkedIn
          </a>

          <a
            href="mailto:r.servin19@hotmail.com"
            class="hover:text-[#86B84C] transition"
          >
            Email
          </a>
        </div>

        <p>©2026</p>

      </div>
    </footer>

  </main>

  <script>
/* EMAIL COPY */
const email = "r.servin19@hotmail.com";

function bindCopy(id: string) {
  const btn = document.getElementById(id);

  if (!btn) return;

  btn.addEventListener("click", async () => {
    await navigator.clipboard.writeText(email);

    const original = btn.textContent;
    btn.textContent = "Copied!";

    setTimeout(() => {
      btn.textContent = original;
    }, 1600);
  });
}

bindCopy("copyEmail");
bindCopy("copyEmail2");


/* HERO TYPING */
const code = `const Regina = {
  role: "Junior Developer",
  skills: ["Java", "Python", "Astro"],
  teamwork: true,
  leadership: true,
  available: true
};`;

const target = document.getElementById("typingCode") as HTMLElement | null;

if (target) {
  let i = 0;

  function typeCode() {
    if (i < code.length) {
      if (!target) return;

      target.textContent += code.charAt(i);
      i++;
      setTimeout(typeCode, 28);
    }
  }

  typeCode();
}


/* HERO CARD SMOOTH PARALLAX */
const wrap = document.getElementById("heroCardWrap") as HTMLDivElement | null;
const card = document.getElementById("heroCard") as HTMLDivElement | null;

if (wrap && card) {
  let targetX = 0;
  let targetY = 0;
  let currentX = 0;
  let currentY = 0;

  function animate() {
    currentX += (targetX - currentX) * 0.06;
    currentY += (targetY - currentY) * 0.06;

    if (!card) return;

    card.style.transform = `
      rotateX(${currentY}deg)
      rotateY(${currentX}deg)
      translateY(-4px)
    `;

    requestAnimationFrame(animate);
  }

  animate();

  wrap.addEventListener("mousemove", (e) => {
    const rect = wrap.getBoundingClientRect();

    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    const centerX = rect.width / 2;
    const centerY = rect.height / 2;

    targetX = (x - centerX) / 28;
    targetY = -(y - centerY) / 28;
  });

  wrap.addEventListener("mouseleave", () => {
    targetX = 0;
    targetY = 0;
  });
}


/* SCROLL REVEAL */
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
}, { threshold: 0.15 });

document.querySelectorAll(".reveal").forEach((el) => {
  observer.observe(el);
});


/* NAVBAR SCROLL EFFECT */
const navbar = document.getElementById("navbar");

window.addEventListener("scroll", () => {
  if (!navbar) return;

  if (window.scrollY > 30) {
    navbar.classList.add(
      "bg-black/80",
      "border-white/10",
      "shadow-[0_10px_30px_rgba(0,0,0,0.35)]"
    );
  } else {
    navbar.classList.remove(
      "bg-black/80",
      "border-white/10",
      "shadow-[0_10px_30px_rgba(0,0,0,0.35)]"
    );
  }
});
</script>
</Layout>
