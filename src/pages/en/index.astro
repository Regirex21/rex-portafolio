---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  lang="en"
  title="Regina Servín | Portfolio"
  description="Portfolio of Regina Servín, software development engineering student and junior developer."
>
  <main class="min-h-screen overflow-x-hidden bg-[#040404] text-white relative pt-1">
    <!-- BACKGROUND GLOWS -->
    <div class="pointer-events-none absolute top-24 right-10 h-[560px] w-[560px] rounded-full bg-[#86B84C]/10 blur-[120px]"></div>
    <div class="pointer-events-none absolute top-[820px] left-[-120px] h-[320px] w-[320px] rounded-full bg-[#86B84C]/4 blur-[100px]"></div>

    <!-- NAVBAR -->
