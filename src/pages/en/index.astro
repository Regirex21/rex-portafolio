    <!-- CONTACT -->
    <section id="contact" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 md:pb-24">
      <div class="rounded-[28px] border border-white/10 bg-[#0b0b0b] p-5 sm:p-8 md:rounded-[32px] md:p-10">

        <div class="grid items-center gap-8 lg:grid-cols-[1fr_auto] reveal">

          <!-- TEXT -->
