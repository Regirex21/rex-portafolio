        </div>

      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 md:pb-28 reveal">

      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between md:mb-10 reveal">
