        <!-- SKILLS -->
        <div class="mt-12 flex flex-wrap gap-3">

          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Java</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Python</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">HTML</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">CSS</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Astro</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Git</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">GitHub</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">VS Code</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Android Studio</span>
          <span class="rounded-full border border-white/10 px-4 py-2 text-sm bg-[#111]">Notion</span>

        </div>

        <!-- INFO BAR -->
        <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4 reveal">

          <!-- UNIVERSITY -->
          <div class="rounded-2xl border border-white/10 bg-[#111] p-5">
            <div class="flex items-start gap-4">
              <img src="/icons/star-svgrepo-com.svg" class="h-8 w-8 mt-1" alt="University" />

              <div>
                <p class="text-sm text-zinc-500">University</p>
                <p class="mt-1 font-semibold">Tecmilenio</p>
              </div>
            </div>
          </div>

          <!-- LANGUAGES -->
          <div class="rounded-2xl border border-white/10 bg-[#111] p-5">
            <div class="flex items-start gap-4">
              <img src="/icons/earth-svgrepo-com.svg" class="h-8 w-8 mt-1" alt="Languages" />

              <div>
                <p class="text-sm text-zinc-500">Languages</p>
                <p class="mt-1 font-semibold">Spanish / English B2+</p>
              </div>
            </div>
          </div>

          <!-- AVAILABILITY -->
          <div class="rounded-2xl border border-white/10 bg-[#111] p-5">
            <div class="flex items-start gap-4">
              <img src="/icons/watch-svgrepo-com.svg" class="h-8 w-8 mt-1" alt="Availability" />

              <div>
