---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  lang="en"
  title="Contact | Regina Servín"
  description="Contact Regina Servín for job opportunities, freelance work, or collaboration."
>
  <main class="min-h-screen overflow-x-hidden bg-[#040404] text-white">

    <!-- HERO -->
    <section class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 sm:px-6 md:pt-10 md:pb-20">

      <div class="absolute left-[-120px] top-10 h-[300px] w-[300px] rounded-full bg-[#86B84C]/10 blur-3xl sm:left-0 sm:h-[360px] sm:w-[360px]"></div>

      <div class="relative z-10 max-w-4xl">

        <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-[#86B84C]">
          Contact
        </span>

        <h1 class="mt-6 text-4xl font-black leading-tight sm:text-5xl md:text-6xl">
          Let's talk.<br />
          <span class="text-[#86B84C]">I am available.</span>
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-7 text-zinc-400 sm:text-lg sm:leading-8">
          Available for internships, part-time roles, freelance work, and junior
          opportunities. If you have an opening, a project, or a collaboration in
          mind, I would be happy to talk.
        </p>

      </div>

    </section>

    <!-- CONTACT GRID -->
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 md:pb-20">

      <div class="grid gap-8 lg:grid-cols-2">

        <!-- LEFT -->
        <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-5 sm:p-8 md:rounded-[32px]">

          <h2 class="text-2xl font-black sm:text-3xl">
            Contact information
          </h2>

          <div class="mt-8 space-y-6">

            <!-- EMAIL -->
            <div class="rounded-2xl border border-white/10 bg-[#0d0d0d] p-5">

              <p class="text-sm text-zinc-500">
                Email
              </p>

              <div class="mt-3 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">

                <span class="text-lg font-medium text-white break-all">
                  r.servin19@hotmail.com
                </span>

                <button
                  id="copyEmail"
                  class="w-full rounded-xl bg-[#86B84C] px-5 py-2 font-semibold text-black transition hover:scale-105 md:w-auto"
                >
                  Copy
                </button>

              </div>

            </div>

            <!-- LINKEDIN -->
            <a
              href="https://www.linkedin.com/in/regina-servín/"
              target="_blank"
              class="block rounded-2xl border border-white/10 bg-[#0d0d0d] p-5 transition hover:border-[#86B84C]"
            >
              <p class="text-sm text-zinc-500">LinkedIn</p>
              <p class="mt-2 break-all text-base font-medium text-white sm:text-lg">
                linkedin.com/in/regina-servín
              </p>
            </a>

            <!-- GITHUB -->
            <a
              href="https://github.com/Regirex21"
              target="_blank"
              class="block rounded-2xl border border-white/10 bg-[#0d0d0d] p-5 transition hover:border-[#86B84C]"
            >
              <p class="text-sm text-zinc-500">GitHub</p>
              <p class="mt-2 break-all text-base font-medium text-white sm:text-lg">
                github.com/Regirex21
              </p>
            </a>

          </div>

        </div>

        <!-- RIGHT -->
        <div class="rounded-[28px] border border-white/10 bg-white/[0.03] p-5 sm:p-8 md:rounded-[32px]">

          <h2 class="text-2xl font-black sm:text-3xl">
            Why contact me?
          </h2>

          <div class="mt-8 space-y-5 text-zinc-300">

            <div class="rounded-2xl border border-white/10 bg-[#0d0d0d] p-5">
              Available for junior opportunities and professional internships.
            </div>

            <div class="rounded-2xl border border-white/10 bg-[#0d0d0d] p-5">
              Interested in freelance projects and remote work.
            </div>

            <div class="rounded-2xl border border-white/10 bg-[#0d0d0d] p-5">
              Experience in leadership, organization, and web development.
            </div>

            <div class="rounded-2xl border border-white/10 bg-[#0d0d0d] p-5">
              Professional response and willingness to learn quickly.
            </div>

          </div>

          <div class="mt-8 rounded-2xl border border-[#86B84C]/20 bg-[#86B84C]/10 p-5">
            <p class="font-semibold text-[#86B84C]">
              Best way to reach me:
            </p>

            <p class="mt-2 text-zinc-200">
              Email or LinkedIn.
            </p>
          </div>

        </div>

      </div>

    </section>

  </main>

  <script>
    const email = "r.servin19@hotmail.com";
    const btn = document.getElementById("copyEmail");

    if (btn) {
      btn.addEventListener("click", async () => {
        await navigator.clipboard.writeText(email);

        const original = btn.textContent;
        btn.textContent = "Copied!";

        setTimeout(() => {
          btn.textContent = original;
        }, 1600);
      });
    }
  </script>
</Layout>
